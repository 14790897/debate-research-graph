---
config:
  flowchart:
    curve: linear
---
graph TD;
	__start__([<p>__start__</p>]):::first
	research(research)
	moderator_opening(moderator_opening)
	proponent(proponent)
	opponent(opponent)
	moderator(moderator)
	__end__([<p>__end__</p>]):::last
	__start__ --> research;
	moderator -.-> __end__;
	moderator -.-> proponent;
	moderator_opening --> proponent;
	opponent --> moderator;
	proponent --> opponent;
	research --> moderator_opening;
	classDef default fill:#f2f0ff,line-height:1.2
	classDef first fill-opacity:0
	classDef last fill:#bfb6fc
